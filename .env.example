# ─── PostgreSQL (Supabase DB) ────────────────────────────────────────────────
POSTGRES_PASSWORD=your-super-secret-postgres-password
POSTGRES_DB=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ─── JWT (Realtime + Kong) ───────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
JWT_EXPIRY=3600

# ─── API Keys (HS256 JWTs — generate with supabase.com/docs/guides/self-hosting#api-keys) ─
ANON_KEY=eyJ...
SERVICE_ROLE_KEY=eyJ...

# ─── Realtime ────────────────────────────────────────────────────────────────
SECRET_KEY_BASE=UpNVntn3cDxHJpq99YMc1T1AQgQpc8kfYTuRgBiYa15BLrx8etQoXz3gZv1/u2oq

# ─── Studio / Dashboard ─────────────────────────────────────────────────────
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=your-dashboard-password
PG_META_CRYPTO_KEY=your-encryption-key-32-chars-min
STUDIO_DEFAULT_ORGANIZATION=WikiGuessr
STUDIO_DEFAULT_PROJECT=WikiGuessr

# ─── Analytics (Logflare) ───────────────────────────────────────────────────
LOGFLARE_PUBLIC_ACCESS_TOKEN=your-logflare-public-key
LOGFLARE_PRIVATE_ACCESS_TOKEN=your-logflare-private-key

# ─── Kong ────────────────────────────────────────────────────────────────────
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

# ─── Supabase public URL (Kong gateway) ─────────────────────────────────────
SUPABASE_PUBLIC_URL=http://localhost:8000

# ─── WikiGuessr App ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:your-super-secret-postgres-password@localhost:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
GAME_TIMEZONE=Europe/Paris
