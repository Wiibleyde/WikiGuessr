// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── User profile (synced from Supabase auth.users via DB trigger) ────────────

model User {
  id            String       @id // Supabase auth UUID
  name          String
  email         String       @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  gameResults   GameResult[]
  gameStates    GameState[]
  coopPlayers   CoopPlayer[]
}

// ─── Application models ────────────────────────────────────────────────────────

model DailyWikiPage {
  id          Int          @id @default(autoincrement())
  title       String
  sections    Json // WikiSection[]
  images      String[] // URLs des images filtrées
  date        DateTime     @unique @db.Date // Une seule page par jour
  url         String       @default("") // URL de la page, pour éviter de devoir la reconstruire
  createdAt   DateTime     @default(now())
  gameResults GameResult[]
  gameStates  GameState[]
}

model GameResult {
  id              Int           @id @default(autoincrement())
  userId          String
  dailyWikiPageId Int
  guessCount      Int
  hintsUsed       Int           @default(0)
  won             Boolean
  createdAt       DateTime      @default(now())
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyWikiPage   DailyWikiPage @relation(fields: [dailyWikiPageId], references: [id], onDelete: Cascade)

  @@unique([userId, dailyWikiPageId])
}

model GameState {
  id              Int           @id @default(autoincrement())
  userId          String
  dailyWikiPageId Int
  guesses         Json // StoredGuess[]
  revealed        Json // RevealedMap
  revealedImages  Json          @default("[]") // string[] — URLs des images d'indices révélées
  won             Boolean       @default(false)
  updatedAt       DateTime      @updatedAt
  createdAt       DateTime      @default(now())
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyWikiPage   DailyWikiPage @relation(fields: [dailyWikiPageId], references: [id], onDelete: Cascade)

  @@unique([userId, dailyWikiPageId])
}

// ─── Co-op models ──────────────────────────────────────────────────────────────

model CoopLobby {
  id           Int          @id @default(autoincrement())
  code         String       @unique
  status       String       @default("waiting") // waiting | playing | finished
  maxPlayers   Int          @default(4)
  wikiTitle    String?
  wikiSections Json? // WikiSection[]
  wikiImages   String[]
  wikiUrl      String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  players      CoopPlayer[]
  guesses      CoopGuess[]
}

model CoopPlayer {
  id          Int         @id @default(autoincrement())
  lobbyId     Int
  userId      String?
  displayName String
  token       String      @unique
  isLeader    Boolean     @default(false)
  joinedAt    DateTime    @default(now())
  lobby       CoopLobby   @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  guesses     CoopGuess[]
}

model CoopGuess {
  id          Int        @id @default(autoincrement())
  lobbyId     Int
  playerId    Int
  word        String
  found       Boolean
  occurrences Int        @default(0)
  similarity  Float      @default(0)
  positions   Json       @default("[]") // WordPosition[]
  createdAt   DateTime   @default(now())
  lobby       CoopLobby  @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  player      CoopPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)
}
